# ---- Recommended: OAuth 2.0 access token -----------------------------------
# Create a Linear OAuth application in
#   Settings -> API -> OAuth applications
# Request the `read` scope, install it to your workspace as an admin, and use
# the "Actor=application" flow so the token is not tied to a single user.
# Paste the resulting access token here.
LINEAR_OAUTH_TOKEN=

# ---- Alternative: personal API key -----------------------------------------
# Only used if LINEAR_OAUTH_TOKEN is empty. Create one in
#   Settings -> Security & access -> Personal API keys
# Tied to the creating user's permissions - if that user leaves the workspace
# the key stops working. Prefer OAuth for production cron jobs.
LINEAR_API_KEY=
