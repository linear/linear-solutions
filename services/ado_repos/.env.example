# =============================================================================
# Linear Authentication (choose one — OAuth is preferred)
# =============================================================================

# Option A (preferred): OAuth App — actions appear as the integration, not a person
# Create an OAuth app at https://linear.app/settings/api/applications
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=

# Option B: Personal API Key — actions appear as the user who created the key
# Generate at https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_xxxxx

# Linear webhook signing secret (from your Linear webhook configuration)
LINEAR_WEBHOOK_SECRET=your-linear-webhook-signing-secret

# =============================================================================
# Azure DevOps Authentication (choose one — OAuth is preferred)
# =============================================================================

# Option A (preferred): Service Principal / Entra ID bearer token
# Actions appear as the service principal, not a person.
# See README for setup instructions.
ADO_OAUTH_TOKEN=

# Option B: Personal Access Token — actions appear as the user who created the token
# Create at https://dev.azure.com/{org}/_usersSettings/tokens with Code (Read & Write) scope
# ADO_PAT=your-ado-personal-access-token

ADO_ORG=your-organization
ADO_PROJECT=your-project

# =============================================================================
# Webhook Security
# =============================================================================

# Webhook auth — generate a random secret (e.g. `openssl rand -hex 32`) and
# include it in your ADO Service Hook URLs as ?secret=<this value>
WEBHOOK_SECRET=your-shared-secret

# =============================================================================
# Server
# =============================================================================

PORT=3000

# =============================================================================
# State mapping (customize to match your team's workflow state names)
# =============================================================================

LINEAR_STATE_STARTED=In Progress
LINEAR_STATE_IN_REVIEW=In Review
LINEAR_STATE_DONE=Done
LINEAR_STATE_CANCELLED=Cancelled
