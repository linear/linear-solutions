# =============================================================================
# Linear Reopen Issue Agent Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Linear OAuth Application (REQUIRED)
# -----------------------------------------------------------------------------
# Create an OAuth application at: Linear Settings > API > Applications
# Enable webhooks and select "Comments" under Data change events
# Set the webhook URL to: https://your-domain.com/reopen-issue
LINEAR_CLIENT_ID=your_client_id
LINEAR_CLIENT_SECRET=your_client_secret
LINEAR_WEBHOOK_SECRET=your_webhook_signing_secret

# -----------------------------------------------------------------------------
# Linear API Token (REQUIRED)
# -----------------------------------------------------------------------------
# Use either a Personal API Key or an OAuth access token.
#
# For Personal API Key (simplest for testing):
#   1. Go to Linear Settings > API > Personal API Keys
#   2. Create a new key and paste it here
#
# For OAuth (recommended for production):
#   Use the access token obtained from the OAuth flow with actor=application
LINEAR_ACCESS_TOKEN=lin_api_xxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
